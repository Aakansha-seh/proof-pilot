# ==========================================================
# ProofPilot — AI provider configuration
# ==========================================================
# Select the active provider. One of: nvidia | fireworks | amd
AI_PROVIDER=nvidia

# ----- NVIDIA (primary provider for development) -----------
# Get a key at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ----- Fireworks (used sparingly for final quality) --------
# Get a key at https://fireworks.ai
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ----- AMD (production claim-analysis inference path) ------
# OpenAI-compatible AMD-hosted endpoint (e.g. AMD Developer Cloud /
# MI300X ROCm vLLM server). AMD runs the central claim-analysis workload.
AMD_API_KEY=
AMD_BASE_URL=
AMD_MODEL=

# ----- Multimodal model override (optional) ----------------
# If your text model is not multimodal, set a vision-capable model here.
# Falls back to <PROVIDER>_MODEL when unset.
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct
FIREWORKS_VISION_MODEL=accounts/fireworks/models/llama-v3p2-90b-vision-instruct
AMD_VISION_MODEL=
