# ==========================================================
# ProofPilot — AI provider configuration
# ==========================================================
# Select the active provider. One of: nvidia | fireworks | amd
AI_PROVIDER=nvidia

# ----- NVIDIA (primary provider for development) -----------
# Get a key at https://build.nvidia.com
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# ----- Fireworks (used sparingly for final quality) --------
# Get a key at https://fireworks.ai
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ----- AMD (production claim-analysis inference path) ------
# OpenAI-compatible AMD-hosted endpoint (e.g. AMD Developer Cloud /
# MI300X ROCm vLLM server). AMD runs the central claim-analysis workload.
AMD_API_KEY=
AMD_BASE_URL=
AMD_MODEL=

# ----- In-app assistant (ProofPilot chatbot) --------------
# The audit assistant reuses the NVIDIA config above by default, so no extra
# setup is needed. Optionally override its endpoint/model here (must be an
# OpenAI-compatible endpoint — e.g. point these at Fireworks or AMD to run the
# assistant through AMD hardware). AI_SYSTEM_PROMPT can replace the built-in
# ProofPilot Mentor prompt.
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_MS=45000
# AI_SYSTEM_PROMPT=

# ----- Competitive Intelligence: web search provider -------
# Free/source-backed research provider for the Competitive Intelligence module.
# Supported: tavily | none  (none = no live search; competitors are labeled
# "Limited recent public activity found in reviewed sources.")
SEARCH_PROVIDER=none
# Get a free key at https://tavily.com
TAVILY_API_KEY=